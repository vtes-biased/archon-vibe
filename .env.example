# Database Configuration
DATABASE_URL=postgresql://archon:archon_dev_password@localhost:5433/archon

# VEKN API Configuration
VEKN_API_BASE_URL=https://www.vekn.net/api
VEKN_API_USERNAME=your_vekn_username
VEKN_API_PASSWORD=your_vekn_password

# VEKN Sync Configuration
VEKN_SYNC_ENABLED=true
VEKN_SYNC_INTERVAL_HOURS=6  # How often to sync (in hours)

# JWT Configuration
JWT_SECRET=dev-secret-change-in-production

# WebAuthn/Passkey Configuration
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Archon
WEBAUTHN_ORIGIN=http://localhost:5173

# Discord OAuth Configuration
DISCORD_CLIENTID=your_discord_client_id
DISCORD_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:8000/auth/discord/callback
FRONTEND_URL=http://localhost:5173

# Email Configuration (Magic Link)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_FROM=noreply@archon.example.com
MAIL_USE_TLS=true

# Github App Credentials
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CLIENT_ID=your_github_client_id

# TWDA GitHub App (auto-PR to GiottoVerducci/TWD)
# Register a GitHub App on the TWD repo with Contents:write + Pull requests:write
TWDA_GITHUB_APP_ID=your_github_app_id
TWDA_GITHUB_PRIVATE_KEY=path/to/private-key.pem
TWDA_GITHUB_INSTALLATION_ID=get_once_installed

# Stage 1: Build WASM engine (same as production Dockerfile)
FROM rust:slim AS wasm-builder
RUN rustup target add wasm32-unknown-unknown && \
    cargo install wasm-pack
WORKDIR /engine
COPY engine/ .
RUN wasm-pack build --no-opt --target web --release --features wasm

# Stage 2: Test runner with Playwright
FROM node:22-slim
WORKDIR /app

# Install Playwright system dependencies and curl
RUN apt-get update && apt-get install -y --no-install-recommends \
    libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0 libcups2 \
    libdrm2 libxkbcommon0 libxcomposite1 libxdamage1 libxfixes3 \
    libxrandr2 libgbm1 libasound2 curl ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Copy WASM engine output to where the $engine alias resolves
COPY --from=wasm-builder /engine/pkg /engine/pkg

# Install dependencies
COPY frontend/package*.json ./
RUN npm ci

# Install Playwright browsers
RUN npx playwright install --with-deps chromium

# Copy frontend source
COPY frontend/ ./

# Fix geonames: copy actual files instead of broken symlink
RUN rm -rf src/lib/data/geonames
COPY backend/src/data/geonames/ src/lib/data/geonames/

# Wait for backend, start dev server, and run tests
CMD ["sh", "-c", "\
    echo 'Waiting for backend...' && \
    timeout 60 sh -c 'until curl -sf http://backend:8000/ > /dev/null; do sleep 1; done' && \
    echo 'Backend ready. Starting Vite dev server...' && \
    npm run dev -- --host 0.0.0.0 & \
    sleep 5 && \
    echo 'Running Playwright tests...' && \
    BASE_URL=http://localhost:5173 npm run test:e2e \
    "]

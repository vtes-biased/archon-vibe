FROM node:22-slim
WORKDIR /app

# Install Playwright system dependencies, curl, build tools, and Rust deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0 libcups2 \
    libdrm2 libxkbcommon0 libxcomposite1 libxdamage1 libxfixes3 \
    libxrandr2 libgbm1 libasound2 curl ca-certificates \
    build-essential pkg-config && \
    rm -rf /var/lib/apt/lists/*

# Install Rust (for building the engine)
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"

# Install wasm-pack
RUN cargo install wasm-pack

# Add wasm32 target
RUN rustup target add wasm32-unknown-unknown

# Copy and build the Rust engine to WASM
COPY engine/ ./engine/
RUN cd engine && wasm-pack build --no-opt --target web --release --features wasm

# Copy package files
COPY frontend/package*.json ./
RUN npm ci

# Install Playwright browsers
RUN npx playwright install --with-deps chromium

# Copy frontend source
COPY frontend/ ./

# Fix geonames symlink - copy actual data files from backend
RUN rm -rf /app/src/data/geonames
COPY backend/src/data/geonames/ /app/src/data/geonames/

# Copy built WASM engine to frontend lib
RUN mkdir -p /app/src/lib/engine && cp -r /app/engine/pkg/* /app/src/lib/engine/

# Wait for backend, start dev server, and run tests
CMD ["sh", "-c", "\
    echo 'Waiting for backend...' && \
    timeout 60 sh -c 'until curl -sf http://backend:8000/ > /dev/null; do sleep 1; done' && \
    echo 'Backend ready. Starting Vite dev server...' && \
    npm run dev -- --host 0.0.0.0 & \
    sleep 5 && \
    echo 'Running Playwright tests...' && \
    BASE_URL=http://localhost:5173 npm run test:e2e \
    "]
